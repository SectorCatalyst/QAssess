NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/qassess
CORS_ALLOWED_ORIGINS=http://127.0.0.1:4173
JWT_ACCESS_SECRET=replace-with-strong-access-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
WEBHOOK_SECRET_ENCRYPTION_KEY=replace-with-strong-webhook-secret-key
STRICT_SECRET_VALIDATION=false
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
PUBLIC_BOOTSTRAP_RATE_LIMIT_PER_MINUTE=120
PUBLIC_SESSION_START_RATE_LIMIT_PER_MINUTE=60
PUBLIC_SESSION_MUTATION_RATE_LIMIT_PER_MINUTE=180
LOG_SERVICE_NAME=qassess-api
# Optional centralized sink forwarding for structured logs:
# LOG_SINK_URL=https://logs.example.com/ingest
# LOG_SINK_TOKEN=replace-with-log-ingest-token
# LOG_SINK_TIMEOUT_MS=2000
PDF_WORKER_BATCH_SIZE=25
WEBHOOK_WORKER_BATCH_SIZE=50
WEBHOOK_WORKER_MAX_ATTEMPTS=6
WEBHOOK_REPLAY_LIMIT=100
